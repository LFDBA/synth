#!/bin/bash
git pull

gpioset 0 26=1
gpioset 0 27=0
gpioset 0 21=0

sudo ./load_synth_program &
LOADER_PID=$!

g++ \
  main.cpp \
  Reverb.cpp \
  font5x7.cpp \
  FFTConvolver.cpp \
  TwoStageFFTConvolver.cpp \
  Utilities.cpp \
  AudioFFT.cpp \
  -o main \
  -O3 -std=c++17 \
  -lportaudio -lpthread -lm -lrtaudio -lasound -lncurses -lpigpio -lrt

kill $LOADER_PID
sudo rm -f /var/run/pigpio.pid
sleep 0.5

sudo ./main

gpioset 0 26=0
gpioset 0 21=0
gpioset 0 27=1